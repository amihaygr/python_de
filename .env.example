# Copy to .env and load in your shell, or export manually (do not commit secrets).

# SQLite database path (optional)
# RETAIL_ETL_DB_PATH=data/db/retail.db

# Default raw CSV path (optional)
# RETAIL_ETL_RAW_CSV=data/raw/retail_sales.csv

# Logging: DEBUG, INFO, WARNING, ERROR
RETAIL_ETL_LOG_LEVEL=INFO

# Streamlit / CLI defaults for Kaggle slug (optional)
# RETAIL_KAGGLE_DATASET=bekkarmerwan/retail-sales-dataset-sample-transactions
# RETAIL_KAGGLE_FILENAME=retail_sales.csv

# Kaggle API (preferred: ~/.kaggle/kaggle.json)
# KAGGLE_USERNAME=
# KAGGLE_KEY=
