# Copy to .env and load in your shell, or export manually (do not commit secrets).

# SQLite database path (optional)
# RETAIL_ETL_DB_PATH=data/db/retail.db

# Default raw CSV path (optional)
# RETAIL_ETL_RAW_CSV=data/raw/retail_sales.csv

# Logging: DEBUG, INFO, WARNING, ERROR
RETAIL_ETL_LOG_LEVEL=INFO

# Streamlit / CLI defaults for Kaggle slug (optional)
# RETAIL_KAGGLE_DATASET=bekkarmerwan/retail-sales-dataset-sample-transactions
# RETAIL_KAGGLE_FILENAME=retail_sales.csv

# Kaggle API — pick one:
# 1) Copy kaggle.json from Kaggle (Account → Settings → API → Create New Token) to:
#    Windows:  %USERPROFILE%\.kaggle\kaggle.json
#    mac/Linux: ~/.kaggle/kaggle.json
# 2) Or uncomment and fill (same username/key as inside kaggle.json):
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# After copying this file to `.env`, Streamlit and the CLI load it automatically (python-dotenv).
# Docker: pass secrets at run time, e.g. -e KAGGLE_USERNAME=... -e KAGGLE_KEY=...
#   or mount read-only: -v %USERPROFILE%\.kaggle:/root/.kaggle:ro
